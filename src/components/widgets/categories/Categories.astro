---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

// 1. 新增：英文分类 → 中文映射（核心修改）
const cnCategoryMap = {
  "tech": "技术",
  "game": "游戏",
  "smart": "智能",
  "Guides": "指南",
  "Examples": "示例",
  "yulu": "语录",
  "uncategorized": "未分类"
};

// 2. 原有逻辑：获取文章并统计分类
const posts = await getCollection('posts');
const categoryMap = new Map<string, number>();

posts.forEach((post: CollectionEntry<'posts'>) => {
  const category = post.data.category || 'uncategorized';
  categoryMap.set(category, (categoryMap.get(category) || 0) + 1);
});

// 3. 新增：转换为带中文名称的分类列表
const categories = Array.from(categoryMap.entries()).sort((a, b) => b[1] - a[1]).map(([enName, count]) => ({
  enName,
  cnName: cnCategoryMap[enName] || enName, // 优先显示中文，无映射则显示原名称
  count
}));
---

<!-- 4. 修改渲染部分：显示中文，链接保留英文 -->
<div class="widget-category">
  <h3 class="widget-title">分类</h3>
  <ul class="category-list">
    {categories.map(({ enName, cnName, count }) => (
      <li key={enName} class="category-item">
        <a href={`/category/${enName}`} class="category-link">
          {cnName} <span class="category-count">({count})</span>
        </a>
      </li>
    ))}
  </ul>
</div>

<!-- 保留原有样式（无需修改） -->
<style>
  .widget-category {
    padding: 1rem;
    border-radius: 8px;
    background: var(--card-bg);
  }
  .widget-title {
    margin: 0 0 1rem 0;
    font-size: 1.1rem;
    font-weight: 600;
  }
  .category-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .category-item {
    margin: 0.5rem 0;
  }
  .category-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--text-color);
    text-decoration: none;
    transition: color 0.2s;
  }
  .category-link:hover {
    color: var(--primary-color);
  }
  .category-count {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }
</style>